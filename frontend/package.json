{
  "name": "smart-home.hub-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ulimit -n 4096 && WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true ng serve shell",
    "start:shell": "ulimit -n 4096 && WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true ng serve shell",
    "start:hubapp": "ulimit -n 4096 && WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true ng serve hubapp",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate:room:api": "openapi --input ./projects/room/auto/api.json --output ./projects/room/auto/client-gen --client fetch"
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ha/components-library": "1.0.114",
    "@microsoft/signalr": "^10.0.0",
    "@softarc/native-federation-node": "^3.3.4",
    "es-module-shims": "^1.5.12",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-architects/native-federation": "^21.2.3",
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "less": "^4.2.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
